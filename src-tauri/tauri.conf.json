{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TPlayer",
  "version": "1.0.1",
  "identifier": "com.tplayer.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TPlayer",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "devtools": true,
        "decorations": false,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "default",
          "description": "Default capabilities",
          "windows": ["main"],
          "permissions": [
            "dialog:allow-open",
            "dialog:default",
            {
              "identifier": "fs:allow-read-text-file",
              "allow": [{"path": "$APPLOCALDATA/*"}, {"path": "$APPLOCALDATA/**/*"}, {"path": "$DESKTOP/*"}, {"path": "$DESKTOP/**/*"}, {"path": "$DOCUMENT/*"}, {"path": "$DOCUMENT/**/*"}, {"path": "$DOWNLOAD/*"}, {"path": "$DOWNLOAD/**/*"}, {"path": "$HOME/*"}, {"path": "$HOME/**/*"}, {"path": "$RESOURCE/*"}, {"path": "$RESOURCE/**/*"}, {"path": "**"}]
            },
            {
              "identifier": "fs:allow-read-file",
              "allow": [{"path": "$APPLOCALDATA/*"}, {"path": "$APPLOCALDATA/**/*"}, {"path": "$DESKTOP/*"}, {"path": "$DESKTOP/**/*"}, {"path": "$DOCUMENT/*"}, {"path": "$DOCUMENT/**/*"}, {"path": "$DOWNLOAD/*"}, {"path": "$DOWNLOAD/**/*"}, {"path": "$HOME/*"}, {"path": "$HOME/**/*"}, {"path": "$RESOURCE/*"}, {"path": "$RESOURCE/**/*"}, {"path": "**"}]
            },
            {
              "identifier": "fs:allow-read-dir",
              "allow": [{"path": "$APPLOCALDATA/*"}, {"path": "$APPLOCALDATA/**/*"}, {"path": "$DESKTOP/*"}, {"path": "$DESKTOP/**/*"}, {"path": "$DOCUMENT/*"}, {"path": "$DOCUMENT/**/*"}, {"path": "$DOWNLOAD/*"}, {"path": "$DOWNLOAD/**/*"}, {"path": "$HOME/*"}, {"path": "$HOME/**/*"}, {"path": "$RESOURCE/*"}, {"path": "$RESOURCE/**/*"}, {"path": "**"}]
            },
            "fs:default",
            "core:webview:allow-internal-toggle-devtools",
            "core:webview:default",
            "core:app:default",
            "core:window:allow-show",
            "core:window:allow-hide",
            "core:window:allow-close",
            "core:window:allow-minimize",
            "core:window:allow-maximize",
            "core:window:allow-unmaximize",
            "core:window:allow-set-focus",
            "core:window:allow-is-visible",
            "core:window:allow-start-dragging",
            "core:event:allow-listen",
            "core:event:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.svg",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {},

    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "fileAssociations": [
      {
        "ext": ["mp3", "flac", "wav", "aac", "ogg", "m4a", "wma"],
        "name": "Audio File",
        "description": "Audio file",
        "role": "Editor"
      }
    ]
  }
}
